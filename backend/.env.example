# URL de conexão do banco (hoje fixa em app/database.py; SQLite no piloto).
# Em produção (HostGator) algo como: mysql://usuario:senha@localhost/nome_do_banco
DATABASE_URL=sqlite:///./piloto_projetos.db

# Origem permitida no CORS (piloto usa "*"; frontend dev roda em Vite).
FRONTEND_ORIGIN=http://localhost:5173
