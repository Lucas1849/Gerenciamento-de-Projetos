# URL de conexão do banco (lida em app/database.py via python-dotenv;
# default sem .env: SQLite local do piloto).
# Em produção (HostGator) algo como: mysql://usuario:senha@localhost/nome_do_banco
DATABASE_URL=sqlite:///./piloto_projetos.db

# Origens permitidas no CORS, separadas por vírgula (lida em main.py;
# default sem .env: "*", aberto — piloto sem autenticação).
# Em produção, restringir ao domínio do Hub.
FRONTEND_ORIGIN=http://localhost:5173
